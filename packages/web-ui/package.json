{
    "name": "@pinnacle0/web-ui",
    "version": "0.7.9",
    "author": "Pinnacle",
    "license": "MIT",
    "sideEffects": [
        "*.less",
        "*.css",
        "./internal/polyfill/*"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/pinnacle0/frontend-libraries.git",
        "directory": "packages/web-ui"
    },
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "build": "pnpm tsx script/build.ts",
        "start": "pnpm tsx script/start.ts",
        "start:mobile": "pnpm tsx script/start-mobile.ts",
        "format": "pnpm tsx script/format.ts",
        "test": "vitest --config ./config/vitest.config.ts --run",
        "prepublishOnly": "pnpm build",
        "demo": "cd demo && pnpm start"
    },
    "dependencies": {
        "@ant-design/react-slick": "^2.0.0",
        "@rc-component/cascader": "^1.14.0",
        "@rc-component/checkbox": "^2.0.0",
        "@rc-component/collapse": "^1.2.0",
        "@rc-component/dialog": "^1.8.4",
        "@rc-component/drawer": "^1.4.2",
        "@rc-component/dropdown": "^1.0.2",
        "@rc-component/image": "^1.6.0",
        "@rc-component/input": "^1.1.2",
        "@rc-component/menu": "^1.2.0",
        "@rc-component/motion": "^1.3.1",
        "@rc-component/notification": "^1.2.0",
        "@rc-component/pagination": "^1.2.0",
        "@rc-component/picker": "^1.9.0",
        "@rc-component/select": "^1.6.13",
        "@rc-component/slider": "^1.0.1",
        "@rc-component/switch": "^1.0.3",
        "@rc-component/table": "^1.9.1",
        "@rc-component/tabs": "^1.7.0",
        "@rc-component/tooltip": "^1.4.0",
        "@rc-component/trigger": "^3.9.0",
        "@rc-component/upload": "^1.1.0",
        "@rc-component/util": "^1.9.0",
        "@tanstack/react-virtual": "3.13.13",
        "classnames": "2.5.1",
        "dayjs": "1.11.19"
    },
    "peerDependencies": {
        "react": ">=19.2.1",
        "react-dom": ">=19.2.1",
        "react-router-dom": "5.2.0 - 5.3.3"
    },
    "devDependencies": {
        "@pinnacle0/devtool-util": "workspace:*",
        "@pinnacle0/webpack-util": "workspace:*",
        "@testing-library/dom": "10.4.1",
        "@testing-library/react": "16.3.0",
        "@testing-library/user-event": "14.6.1",
        "@types/react": "19.2.7",
        "@types/react-dom": "19.2.3",
        "@types/react-router": "5.1.20",
        "@types/react-router-dom": "5.3.3",
        "history": "5.3.0",
        "jsdom": "27.0.0",
        "less": "4.4.1",
        "react": "19.2.1",
        "react-dom": "19.2.1",
        "react-router-dom": "5.3.0"
    },
    "exports": {
        "./core/*": "./src/core/*/index.tsx",
        "./hooks/*": "./src/hooks/*/index.ts",
        "./admin/*": "./src/admin/*/index.tsx",
        "./util/*": "./src/util/*/index.tsx",
        "./css/*": "./src/css/*.less"
    },
    "publishConfig": {
        "directory": "build",
        "linkDirectory": false,
        "exports": {
            "./core/*": {
                "import": "./core/*/index.js",
                "types": "./core/*/index.d.ts"
            },
            "./hooks/*": {
                "import": "./hooks/*/index.js",
                "types": "./hooks/*/index.d.ts"
            },
            "./admin/*": {
                "import": "./admin/*/index.js",
                "types": "./admin/*/index.d.ts"
            },
            "./util/*": {
                "import": "./util/*/index.js",
                "types": "./util/*/index.d.ts"
            },
            "./css/*.less": "./css/*.less"
        }
    }
}
